VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SENTRY_DSN=https://your-sentry-dsn
VITE_GA_ID=G-XXXXXXXXXX

# Lenis smooth wheel (on by default on desktop; set false for native scroll).
# VITE_ENABLE_SMOOTH_SCROLL=false

# Supabase Edge Function secret (Dashboard → Edge Functions → Secrets), not Vite.
# Usually unnecessary on Hostido when the site is on vezvision.com / www (already in edge CORS).
# Only for extra origins (staging subdomain, temporary host URL, alternate domain):
# ALLOWED_CORS_ORIGINS=https://staging.vezvision.com
