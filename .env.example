VITE_SITE_URL=https://vezvision.com
VITE_API_URL=https://api.vezvision.com
# Public MinIO/S3-compatible bucket endpoint, without a trailing slash.
VITE_PUBLIC_ASSETS_URL=https://assets.vezvision.com
VITE_SENTRY_DSN=https://your-sentry-dsn
VITE_GA_ID=G-XXXXXXXXXX
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Server-only VEZcore administration gateway. Keep these values in Coolify.
ADMIN_API_TOKEN_SHA256=
ADMIN_POSTGREST_URL=http://vezvision-admin-postgrest:3000
ADMIN_POSTGREST_API_KEY=

# Public API server settings belong in Coolify and must never use the VITE_ prefix.
# DATABASE_URL=postgresql://restricted_api_user:password@postgres:5432/vezvision
# ALLOWED_ORIGINS=https://vezvision.com,https://www.vezvision.com
# TURNSTILE_SECRET_KEY=
# RESEND_API_KEY=
