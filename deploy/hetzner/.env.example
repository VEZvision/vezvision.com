# Set in Coolify; do not commit real values.
DATABASE_URL=postgresql://vezvision_api:REPLACE_ME@DATABASE_HOST:5432/vezvision
ALLOWED_ORIGIN=https://REPLACE_WITH_VEZVISION_DOMAIN
# Optional comma-separated override for multiple website origins.
ALLOWED_ORIGINS=
# Required when VITE_TURNSTILE_SITE_KEY is enabled in the frontend.
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAMES=vezvision.com,www.vezvision.com
TURNSTILE_TEST_MODE=false
RESEND_API_KEY=
CONTACT_FROM_EMAIL=contact@vezvision.com
CONTACT_NOTIFICATION_FROM_EMAIL=notifications@vezvision.com
CONTACT_REPLY_FROM_EMAIL=contact@vezvision.com
CONTACT_NOTIFY_EMAIL=contact@vezvision.com
