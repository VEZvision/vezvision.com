{
  "name": "vezvision_web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync:security-headers": "node --env-file-if-exists=.env scripts/sync-security-headers.mjs",
    "verify:security": "node --env-file-if-exists=.env scripts/verify-security-headers.mjs",
    "verify:edge-shared": "node scripts/verify-edge-shared-parity.mjs",
    "test:csp": "node --env-file-if-exists=.env --test scripts/csp-policy.test.mjs",
    "test:scripts": "node --env-file-if-exists=.env --test scripts/csp-policy.test.mjs && npx tsx --test scripts/seo-build-validation.test.ts",
    "build": "npm run sync:security-headers && npm run verify:security && npm run typecheck && vitest --run src/data/translations/parity.test.ts && npm run verify:edge-shared && npm run generate-sitemap && npm run generate-robots-txt && npm run generate-rss-feeds && npm run generate-llms-full && node --env-file-if-exists=.env ./node_modules/vite/bin/vite.js build && npx tsx --env-file-if-exists=.env scripts/prerender-head.ts && node scripts/copy-spa-index-to-locale-dirs.mjs && npx tsx --env-file-if-exists=.env scripts/verify-production-build.ts",
    "lint": "eslint .",
    "knip": "knip",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "check": "npm run typecheck && vitest --run src/data/translations/parity.test.ts && npm run test:unit && npm run verify:edge-shared && npm run test:scripts",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:unit:coverage": "vitest --run --coverage",
    "test:edge": "deno test --no-lock --allow-env supabase/functions/_shared/",
    "check:edge": "deno lint --config supabase/functions/deno.json supabase/functions/",
    "test:e2e": "E2E_BUILD=1 npm run build && E2E_USE_PREBUILT_DIST=1 playwright test",
    "test:e2e:prebuilt": "E2E_USE_PREBUILT_DIST=1 playwright test",
    "test:e2e:live": "E2E_LIVE_SUPABASE=1 playwright test tests/e2e/live-supabase.spec.ts --project=chromium",
    "test:ui": "vitest --ui",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "generate-sitemap": "npx tsx --env-file-if-exists=.env scripts/generate-sitemap.ts",
    "generate-robots-txt": "npx tsx --env-file-if-exists=.env scripts/generate-robots-txt.ts",
    "generate-rss-feeds": "npx tsx --env-file-if-exists=.env scripts/generate-rss-feeds.ts",
    "generate-llms-full": "npx tsx --env-file-if-exists=.env scripts/generate-llms-full.ts",
    "generate-og-image": "node scripts/generate-og-image.mjs",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "prerender-head": "npx tsx --env-file-if-exists=.env scripts/prerender-head.ts",
    "split-translations": "node scripts/split-translations.mjs",
    "gen:types": "npx supabase gen types typescript --project-id pcxcqbpygyidkusetghk > src/types/database.types.ts",
    "gen:types:local": "supabase gen types typescript --local > src/types/database.types.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@sentry/react": "^10.65.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "dompurify": "^3.4.12",
    "lenis": "^1.3.25",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "sonner": "^2.0.7",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.25.0",
    "@playwright/test": "^1.60.0",
    "@size-limit/preset-app": "^12.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.30",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.0.14",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "deno-bin": "^2.2.7",
    "eslint": "^9.25.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "knip": "^6.17.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.12",
    "prettier": "^3.8.4",
    "sass-embedded": "^1.93.1",
    "sharp": "^0.33.5",
    "size-limit": "^12.1.0",
    "supabase": "^2.109.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.23.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.4.3",
    "vite-imagetools": "^7.1.1",
    "vite-plugin-compression2": "^2.5.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.14"
  },
  "engines": {
    "node": ">=22"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix",
    "*.{ts,tsx,css,md,json}": "prettier --write"
  }
}
