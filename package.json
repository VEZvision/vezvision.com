    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.9.2",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
